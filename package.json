{
  "name": "dnd-toolkit",
  "productName": "DnD Toolkit",
  "version": "1.6.0",
  "description": "Umfassendes D&D 5e Toolkit für Dungeon Master – Händler, Encounter, Städte und mehr",
  "main": "main.js",
  "author": "Nic",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "release": "electron-builder --win --publish always"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.2.1"
  },
  "build": {
    "appId": "de.nic.dndtoolkit",
    "productName": "DnD Toolkit",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "data/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "zip", "arch": ["x64"] }
      ],
      "icon": "build/icon.ico",
      "publisherName": "Nic Klops",
      "legalTrademarks": "MIT-Lizenz",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "DnD-Toolkit-Setup-${version}.${ext}",
      "shortcutName": "DnD Toolkit",
      "uninstallDisplayName": "DnD Toolkit ${version}"
    },
    "publish": {
      "provider": "github",
      "owner": "klopsnic-cyber",
      "repo": "DnDToolkit",
      "releaseType": "release"
    }
  }
}
